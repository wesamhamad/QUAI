# ─── Required for OpenAI (RAG answer engine + eval judge + dataset rebuild) ───
OPENAI_API_KEY=sk-proj-...
# Optional: override base URL (e.g. for Azure OpenAI or a proxy)
# OPENAI_BASE_URL=
# Optional: organization / project IDs
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# ─── Optional: better Arabic embeddings (recommended for production) ───
# If unset, falls back to sentence-transformers BGE-M3 (free, runs locally, multilingual).
VOYAGE_API_KEY=

# ─── Models ───
QU_ANSWER_MODEL=gpt-4o
QU_FAST_MODEL=gpt-4o-mini
QU_JUDGE_MODEL=gpt-4o
QU_DATASET_MODEL=gpt-4o-mini
QU_EMBEDDING_MODEL=text-embedding-3-large

# ─── Storage paths (relative to repo root) ───
QU_DATA_DIR=data
QU_INDEX_DIR=data/index
QU_RUNS_DIR=runs
