							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"messages\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"اكتب فقرة عن التحول الرقمي\"\n        }\n    ],\n    \"stream\": true,\n    \"web_search\": false\n}"
