							"raw": "{\n    \"messages\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"ما آخر أخبار جامعة القصيم؟\"\n        }\n    ],\n    \"stream\": false,\n    \"web_search\": true\n}"
