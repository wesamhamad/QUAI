	"item": [
		{
			"name": "Course Quiz",
			"description": "Course quiz generation from Blackboard attachments",
			"item": [
				{
					"name": "Generate Quiz",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"course_id\": \"{{course_id}}\",\n    \"content_id\": \"{{content_id}}\",\n    \"attachment_id\": \"{{attachment_id}}\",\n    \"lang\": \"ar\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/course-quiz/generate",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "course-quiz", "generate"]
						},
						"description": "Generate 18 MCQ questions from a Blackboard course attachment.\n\nRequires SAML session authentication and student_id.\n\n**Body:**\n- `course_id` (required) — Blackboard course ID (format: degree_campus_semester_course_section)\n- `content_id` (required) — Blackboard content ID\n- `attachment_id` (required) — Blackboard attachment ID\n- `lang` (optional) — ar or en (default: ar)\n\n**Response:** 18 questions: 6 easy (enemy), 6 medium (minion), 6 hard (boss)"
					}
				}
			]
		},
		{
