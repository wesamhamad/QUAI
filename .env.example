APP_NAME=QUAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8007

# Base URL of the standalone Q SPARK demo (./QSPARK), a separate app with its
# own /dev/{role} routes. Local: php artisan serve --port=8001 inside ./QSPARK.
QSPARK_DEMO_URL=http://127.0.0.1:8001

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# ── AI Provider ──
# "ollama" for local Ollama
AI_PROVIDER=ollama

# Ollama API Configuration (local, used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=iKhalid/ALLaM:7b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_CTX=32768

# ── QU Agent / Embeddings ──
QUAI_AGENT_ENGLISH_MODEL=llama-3.1-8b-instant
QUAI_AGENT_MAX_HISTORY=20
QUAI_AGENT_MAX_FILES=null
QUAI_AGENT_ENFORCE_FILE_ISOLATION=true
QUAI_AGENT_MAX_FILE_SIZE=10240
QUAI_AGENT_USE_SEMANTIC_SEARCH=false
COOP_TRAINING_SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL=86400
QUAI_EMBEDDINGS_PROVIDER=ollama
QUAI_EMBEDDINGS_MODEL=nomic-embed-text
QUAI_EMBEDDINGS_BASE_URL=http://localhost:11434
QUAI_EMBEDDINGS_TIMEOUT=30
QUAI_EMBEDDINGS_CACHE_TTL=3600

# ── SearXNG Web Search (self-hosted via Docker) ──
SEARXNG_BASE_URL=http://localhost:8888
SEARXNG_TIMEOUT=10
SEARXNG_MAX_RESULTS=5

# ── Microsoft Clarity (UX analytics) ──
# Generate one Data Export API token per project at clarity.microsoft.com → Settings → Data Export
CLARITY_API_BASE_URL=https://www.clarity.ms/export-data/api/v1
CLARITY_TIMEOUT=30
CLARITY_DEFAULT_DAYS=3
FACULTY_ClARITY_API_KEY=
MYQU_ClARITY_API_KEY=
QU_WEBSITE_ClARITY_API_KEY=

# ── QU Feedback board (api.qu.edu.sa/api/v1/feedback) ──
QU_FEEDBACK_BASE_URL=https://api.qu.edu.sa/api/v1
QU_API_KEY=
QU_FEEDBACK_TIMEOUT=30
QU_FEEDBACK_PER_PAGE=100
QU_FEEDBACK_DEMO_FALLBACK=true
CLARITY_DEMO_FALLBACK=true

# ── File Extraction Microservice ──
FILE_EXTRACTION_BASE_URL=http://localhost:8001
FILE_EXTRACTION_TIMEOUT=60
FILE_EXTRACTION_FALLBACK=true

# ── Blackboard / QU API v2 ──
# Local dev defaults: qu-api-v2 on :8009, MyQuSSO on :8000.
# Switch these to https://api.qu.edu.sa for production.
BLACKBOARD_API_BASE_URL=http://127.0.0.1:8009/api/v2
BLACKBOARD_SERVICE_TOKEN=
BLACKBOARD_TIMEOUT=30
# MyQU /web/login redirect target. Lives on qu-api-v2 (NOT MyQuSSO).
MYQU_LOGIN_URL=http://127.0.0.1:8009/web/login
UNIVERSITY_API_TOKEN_TTL=24

# ── QU API v1 (academic plan, departments, skills) ──
# Separate from Blackboard; uses its own origin token.
QU_API_V1_BASE_URL=http://127.0.0.1:8009/api/v1
# Origin token — format: 'qu-api|<40-random-chars>'. Registered in qu-api-v2 origins table.
QU_API_V1_ORIGIN_TOKEN=
QU_API_V1_TIMEOUT=30

# ── Skills Record API (سجلك الرقمي) ──
SKILLS_RECORD_BASE_URL=https://skill.qu.edu.sa/api
SKILLS_RECORD_API_KEY=
SKILLS_RECORD_TIMEOUT=20
SKILLS_RECORD_CACHE_TTL=300
SKILLS_RECORD_DEFAULT_YEAR=1446

# ── AI labor-market analysis (سجلك الرقمي → تحليل سوق العمل) ──
# Phase 1: AI gap-analysis. Phase 2: live scraping.
LABOR_MARKET_MODEL=allam-2-7b
LABOR_MARKET_CACHE_TTL=86400
LABOR_MARKET_TIMEOUT=60
LABOR_MARKET_MAX_TOKENS=2000
# Phase 2 scraper (Google Jobs + Coursera/Udemy/Misk via Oxylabs residential proxy).
# Set LABOR_MARKET_SCRAPER_ENABLED=true once OXYLABS_PROXY_URL is filled in.
LABOR_MARKET_SCRAPER_ENABLED=false
OXYLABS_PROXY_URL=
LABOR_MARKET_SCRAPER_TIMEOUT=60
LABOR_MARKET_SCRAPER_SLEEP_MS=1200
LABOR_MARKET_MAX_JOBS_PER_QUERY=10
LABOR_MARKET_MAX_COURSES_PER_QUERY=6
LABOR_MARKET_FRESHNESS_DAYS=7

# ── Content Moderation ──
QUAI_MODERATION_ENABLED=true

# ── Course Quiz ──
COURSE_QUIZ_MAX_TOKENS=8192
COURSE_QUIZ_MAX_CONTENT=30000

# ── Vibe Coding (Python Executor) ──
VIBE_CODING_MAX_TOKENS=8192
VIBE_CODING_MAX_HISTORY=20
VIBE_CODING_MAX_CODE_LENGTH=100000
PYTHON_EXECUTOR_BASE_URL=http://localhost:8003
PYTHON_EXECUTOR_TIMEOUT=30
PYTHON_MAX_EXEC_TIME=10
PYTHON_MAX_MEMORY=128
PYTHON_EXECUTOR_ENABLED=true

# ── IP Whitelist (comma-separated, leave empty to allow all) ──
QUAI_ALLOWED_IPS=

# ── Rate Limiting ──
QUAI_RATE_LIMIT_ENABLED=true
QUAI_RATE_LIMIT_MAX=60
QUAI_RATE_LIMIT_DECAY=1

# ── Logging ──
QUAI_LOGGING_ENABLED=true
QUAI_LOG_CHANNEL=quai

# ── Default Generation Parameters ──
QUAI_DEFAULT_MAX_TOKENS=8192
QUAI_DEFAULT_TEMPERATURE=0.7
QUAI_DEFAULT_TOP_P=0.9

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── Smart Advisor ──
SMART_ADVISOR_MAX_TOKENS=8192
SMART_ADVISOR_MAX_HISTORY=30
SMART_ADVISOR_KB_PATH=advisor_knowledge
SMART_ADVISOR_MAX_KB_CHARS=30000
SMART_ADVISOR_CACHE_TTL=300

# Smart Advisor - AI Intent Detection
SMART_ADVISOR_AI_INTENT=true
SMART_ADVISOR_INTENT_MAX_TOKENS=250
SMART_ADVISOR_INTENT_TEMPERATURE=0.1

# Smart Advisor - Semantic Search (Python RAG service)
SMART_ADVISOR_SEMANTIC_SEARCH=false
SMART_ADVISOR_SEMANTIC_URL=http://localhost:8002
SMART_ADVISOR_SEMANTIC_TIMEOUT=15
SMART_ADVISOR_SEMANTIC_TOP_K=10
